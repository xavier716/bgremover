# Remove.bg API Key
REMOVEBG_API_KEY=your_api_key_here

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key

# PayPal Configuration (Sandbox)
NEXT_PUBLIC_PAYPAL_CLIENT_ID_SANDBOX=your_paypal_sandbox_client_id
PAYPAL_CLIENT_SECRET_SANDBOX=your_paypal_sandbox_client_secret
PAYPAL_MODE_SANDBOX=sandbox

# PayPal Configuration (Live)
NEXT_PUBLIC_PAYPAL_CLIENT_ID_LIVE=your_paypal_live_client_id
PAYPAL_CLIENT_SECRET_LIVE=your_paypal_live_client_secret
PAYPAL_MODE_LIVE=live

# Vercel Postgres
POSTGRES_URL=your_postgres_url
POSTGRES_PRISMA_URL=your_postgres_prisma_url
