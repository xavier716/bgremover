# Remove.bg API Key
# Get your free API key from: https://www.remove.bg/api
# Free tier: 50 images/month
REMOVEBG_API_KEY=your_api_key_here

# NextAuth.js Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# NextAuth.js - Google OAuth
# Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth.js - GitHub OAuth
# Get from: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# PayPal Configuration (Sandbox)
# Get credentials from: https://developer.paypal.com/dashboard/
NEXT_PUBLIC_PAYPAL_CLIENT_ID_SANDBOX=your_paypal_sandbox_client_id_here
PAYPAL_CLIENT_SECRET_SANDBOX=your_paypal_sandbox_client_secret_here
PAYPAL_MODE_SANDBOX=sandbox

# PayPal Configuration (Live)
NEXT_PUBLIC_PAYPAL_CLIENT_ID_LIVE=your_paypal_live_client_id_here
PAYPAL_CLIENT_SECRET_LIVE=your_paypal_live_client_secret_here
PAYPAL_MODE_LIVE=live

# Vercel Postgres
# Automatically configured by Vercel
POSTGRES_URL=your_postgres_url
DATABASE_URL=your_postgres_url
